# Supabase — persistência na nuvem (dados + imagens globais).
# Pegue em: Supabase → Project Settings → API.
# Sem estas vars, o app cai no modo offline (localStorage, só no navegador local).
#
# Project URL
VITE_SUPABASE_URL="https://SEU-PROJETO.supabase.co"
# anon public key (segura para o frontend — protegida por RLS)
VITE_SUPABASE_ANON_KEY="MINHA_ANON_KEY"
